        [IntRange] _DateFontCols ("Font Columns", Range(1, 32)) = 4
        [IntRange] _DateFontRows ("Font Rows", Range(1, 32)) = 4

        // Automatically kept in sync by VRCLocalDateOverlayShaderGUI for Scene-view preview.
        [HideInInspector] _EditorDate ("", Float) = 1773446400
    }

    SubShader
    {
        Tags
        {
            "RenderType"="Transparent"
            "Queue"="Transparent"
            "IgnoreProjector"="True"
        }

        // This shader is intended to be used as a transparent overlay only.
        // The base liltoon look should be rendered by a separate material.

        // ── Workaround for Unity bug IN-60271 ────────────────────────────────
        // Prevents Unity from stripping UV channels used inside UsePass shaders.
        // LightMode Never means this pass is never actually executed.
        Pass
        {
            Tags { "LightMode" = "Never" }
            HLSLPROGRAM
            #pragma vertex vert
            #pragma fragment frag
            struct appdata {
                float2 uv:TEXCOORD0; float2 uv1:TEXCOORD1;
                float2 uv2:TEXCOORD2; float2 uv3:TEXCOORD3;
                float2 uv4:TEXCOORD4; float2 uv5:TEXCOORD5;
                float2 uv6:TEXCOORD6; float2 uv7:TEXCOORD7;
                float4 color:COLOR; float3 normalOS:NORMAL; float4 tangentOS:TANGENT;
                #if !defined(SHADER_API_MOBILE) && !defined(SHADER_API_GLES)
                uint vertexID:SV_VertexID;
                #endif
                float4 pos:POSITION;
            };
            struct v2f { float4 pos:POSITION; float4 col:TEXCOORD0; };
            struct v2f vert(struct appdata i) {
                struct v2f o; o.pos = float4(0,0,0,1);
                o.col = float4(i.uv,i.uv1)+float4(i.uv2,i.uv3)
                      + float4(i.uv4,i.uv5)+float4(i.uv6,i.uv7)
                      + i.color + float4(i.normalOS,1) + i.tangentOS;
                #if !defined(SHADER_API_MOBILE) && !defined(SHADER_API_GLES)
                o.col.a += i.vertexID;
                #endif
                return o;
            }
            float4 frag(v2f i) : SV_Target { return i.col; }
            ENDHLSL
        }

        // ── Date / Time overlay pass ──────────────────────────────────────────
        // Only the glyph area is drawn; the rest of the material stays transparent.
        Pass
        {
            Name "DATE_OVERLAY"
            Tags { "LightMode" = "Always" }
            Blend SrcAlpha OneMinusSrcAlpha
            ZWrite Off
            ZTest LEqual
            Cull Off


            HLSLPROGRAM
            #pragma vertex vert
            #pragma fragment fragRender
            #include "UnityCG.cginc"
            #include "Packages/com.vrchat.base/ShaderLibrary/VRCTime.cginc"

            float4 _Color;
            sampler2D _MainTex;
            float4 _MainTex_ST;
            float  _DateEnable;
            float4 _DateTex_ST;
            int    _DateFormat;
            int    _DateShowFlags;
            int    _DateHourMode;
            float  _DateShowAmPm;
            float  _DateUseFontTex;
            sampler2D _DateFontTex;
            float  _DateFontCols;
            float  _DateFontRows;
            float  _EditorDate;

            struct appdata { float4 vertex : POSITION; float2 uv : TEXCOORD0; };
            struct v2f     { float4 pos : SV_POSITION; float2 uv : TEXCOORD0; };

            v2f vert(appdata v)
            {
                v2f o;
                o.pos = UnityObjectToClipPos(v.vertex);
                o.uv  = v.uv;
                return o;
            }

            float RRectSDF(float2 p, float2 center, float2 halfSize, float r)
            {
                float2 d = abs(p - center) - max(halfSize - r, 0.0);
                return length(max(d, 0.0)) + min(max(d.x, d.y), 0.0) - r;
            }

            float HSegSDF(float2 uv, float cy, float x0, float x1, float thick, float r)
            {
                return RRectSDF(uv, float2((x0+x1)*0.5, cy), float2((x1-x0)*0.5, thick), r);
            }

            float VSegSDF(float2 uv, float cx, float y0, float y1, float thick, float r)
            {
                return RRectSDF(uv, float2(cx, (y0+y1)*0.5), float2(thick, (y1-y0)*0.5), r);
            }

            float DrawDigit(float2 uv, int digit)
            {
                static const uint kSegs[10] = {
                     63u, 6u, 91u, 79u, 102u, 109u, 125u, 7u, 127u, 111u
                };
                uint mask = kSegs[clamp(digit, 0, 9)];

                const float T   = 0.09; const float R   = 0.05;
                const float X0  = 0.15; const float X1  = 0.85;
                const float YT  = 0.91; const float YM  = 0.50; const float YB  = 0.09;
                const float GAP = 0.03; const float AA  = 0.025;

                float d = 1e6;
                if (mask &  1u) d = min(d, HSegSDF(uv, YT, X0, X1, T, R));
                if (mask &  2u) d = min(d, VSegSDF(uv, X1, YM+T+GAP, YT-T-GAP, T, R));
                if (mask &  4u) d = min(d, VSegSDF(uv, X1, YB+T+GAP, YM-T-GAP, T, R));
                if (mask &  8u) d = min(d, HSegSDF(uv, YB, X0, X1, T, R));
                if (mask & 16u) d = min(d, VSegSDF(uv, X0, YB+T+GAP, YM-T-GAP, T, R));
                if (mask & 32u) d = min(d, VSegSDF(uv, X0, YM+T+GAP, YT-T-GAP, T, R));
                if (mask & 64u) d = min(d, HSegSDF(uv, YM, X0, X1, T, R));
                return 1.0 - smoothstep(-AA, AA, d);
            }

            float DrawSlash(float2 uv)
            {
                float dist = abs(2.0*uv.x - uv.y - 0.5) * 0.4472135955;
                float clip = step(0.05,uv.x)*step(uv.x,0.95)*step(0.02,uv.y)*step(uv.y,0.98);
                return (1.0 - smoothstep(0.065, 0.115, dist)) * clip;
            }

            float DrawHyphen(float2 uv)
            {
                float dx = abs(uv.x-0.5); float dy = abs(uv.y-0.5);
                return (1.0-smoothstep(0.305,0.355,dx))*(1.0-smoothstep(0.065,0.115,dy));
            }

            float DrawColon(float2 uv)
            {
                const float R = 0.07; const float AA = 0.025;
                float2 q1 = abs(uv - float2(0.50, 0.68)) - float2(0.09, 0.09);
                float  f1 = length(max(q1, 0.0)) + min(max(q1.x, q1.y), 0.0) - R;
                float2 q2 = abs(uv - float2(0.50, 0.32)) - float2(0.09, 0.09);
                float  f2 = length(max(q2, 0.0)) + min(max(q2.x, q2.y), 0.0) - R;
                return 1.0 - smoothstep(-AA, AA, min(f1, f2));
            }

            float4 SampleFontTex(float2 uv, int content, float cols, float rows)
            {
                float slot;
                if      (content >= 0)  slot = (float)clamp(content, 0, 9);
                else if (content == -1) slot = 10.0;
                else if (content == -2) slot = 11.0;
                else if (content == -3) slot = 12.0;
                else if (content == -5) slot = 13.0;
                else if (content == -6) slot = 14.0;
                else                    slot = 15.0;

                float safeCols = max(cols, 1.0);
                float safeRows = max(rows, 1.0);
                float col = fmod(slot, safeCols);
                float row = floor(slot / safeCols);
                float2 atlasUV = float2((col + uv.x) / safeCols, 1.0 - ((row + 1.0 - uv.y) / safeRows));
                return tex2D(_DateFontTex, atlasUV);
            }

            void CivilFromDays(uint z, out int y, out int m, out int d)
            {
                z += 719468u;
                uint era = z/146097u; uint doe = z-era*146097u;
                uint yoe = (doe-doe/1460u+doe/36524u-doe/146096u)/365u;
                uint doy = doe-(365u*yoe+yoe/4u-yoe/100u);
                uint mp  = (5u*doy+2u)/153u;
                d = (int)(doy-(153u*mp+2u)/5u+1u);
                m = (int)mp + ((int)mp < 10 ? 3 : -9);
                y = (int)(yoe+era*400u) + (m<=2 ? 1 : 0);
            }

            // ─── Cell layout helpers ─────────────────────────────────────────────────────
            // _DateShowFlags bits: 1=Year 2=Month 4=Day 8=Hour 16=Minute 32=Second
            // content codes: >=0 digit  -1 slash  -2 hyphen  -3 colon  -4 empty  -5 AM  -6 PM
            int GetTotalCells(int fmt, int flags, bool showAmPm)
            {
                bool sY=(flags&1)!=0; bool sMo=(flags&2)!=0; bool sD=(flags&4)!=0;
                bool sH=(flags&8)!=0; bool sMi=(flags&16)!=0; bool sS=(flags&32)!=0;
                int n=0; bool p=false;
                if(fmt==1){if(sMo){n+=2;p=true;}if(sD){if(p)n++;n+=2;p=true;}if(sY){if(p)n++;n+=4;}}
                else if(fmt==2){if(sD){n+=2;p=true;}if(sMo){if(p)n++;n+=2;p=true;}if(sY){if(p)n++;n+=4;}}
                else{if(sY){n+=4;p=true;}if(sMo){if(p)n++;n+=2;p=true;}if(sD){if(p)n++;n+=2;}}
                int dc=n; n=0; bool tp=false;
                if(sH){n+=2;tp=true;}if(sMi){if(tp)n++;n+=2;tp=true;}if(sS){if(tp)n++;n+=2;}
                if(showAmPm && tp) n += 2;
                return dc+((dc>0&&n>0)?1:0)+n;
            }

            int GetCellContent(int fmt, int flags, bool showAmPm, bool isPM, int cell,
                               int y0,int y1,int y2,int y3,
                               int m0,int m1,int d0,int d1,
                               int h0,int h1,int mi0,int mi1,int s0,int s1)
            {
                bool sY=(flags&1)!=0; bool sMo=(flags&2)!=0; bool sD=(flags&4)!=0;
                bool sH=(flags&8)!=0; bool sMi=(flags&16)!=0; bool sS=(flags&32)!=0;
                int ds=(fmt==3)?-2:-1; int c=0; bool dp=false;
                if(fmt==1)
                {
                    if(sMo){if(cell==c)return m0;c++;if(cell==c)return m1;c++;dp=true;}
                    if(sD){if(dp){if(cell==c)return ds;c++;}if(cell==c)return d0;c++;if(cell==c)return d1;c++;dp=true;}
                    if(sY){if(dp){if(cell==c)return ds;c++;}if(cell==c)return y0;c++;if(cell==c)return y1;c++;if(cell==c)return y2;c++;if(cell==c)return y3;c++;}
                }
                else if(fmt==2)
                {
                    if(sD){if(cell==c)return d0;c++;if(cell==c)return d1;c++;dp=true;}
                    if(sMo){if(dp){if(cell==c)return ds;c++;}if(cell==c)return m0;c++;if(cell==c)return m1;c++;dp=true;}
                    if(sY){if(dp){if(cell==c)return ds;c++;}if(cell==c)return y0;c++;if(cell==c)return y1;c++;if(cell==c)return y2;c++;if(cell==c)return y3;c++;}
                }
                else
                {
                    if(sY){if(cell==c)return y0;c++;if(cell==c)return y1;c++;if(cell==c)return y2;c++;if(cell==c)return y3;c++;dp=true;}
                    if(sMo){if(dp){if(cell==c)return ds;c++;}if(cell==c)return m0;c++;if(cell==c)return m1;c++;dp=true;}
                    if(sD){if(dp){if(cell==c)return ds;c++;}if(cell==c)return d0;c++;if(cell==c)return d1;c++;}
                }
                bool hd=sY||sMo||sD; bool ht=sH||sMi||sS;
                if(hd&&ht){if(cell==c)return -4;c++;}
                bool tp=false;
                if(sH){if(cell==c)return h0;c++;if(cell==c)return h1;c++;tp=true;}
                if(sMi){if(tp){if(cell==c)return -3;c++;}if(cell==c)return mi0;c++;if(cell==c)return mi1;c++;tp=true;}
                if(sS){if(tp){if(cell==c)return -3;c++;}if(cell==c)return s0;c++;if(cell==c)return s1;c++;}
                if(showAmPm && tp)
                {
                    if(cell==c)return -4; c++;
                    if(cell==c)return isPM ? -6 : -5; c++;
                }
                return -4;
            }

            float GetDateOverlayAlpha(float2 meshUV)
            {
                // _DateTex_ST.xy = tiling (1/w, 1/h), .zw = offset (-x/w, -y/h)
                float2 localUV = meshUV * _DateTex_ST.xy + _DateTex_ST.zw;
                if (any(localUV < 0.0) || any(localUV > 1.0))
                    return 0.0;

                uint utcSeconds = VRC_GetUTCUnixTimeInSeconds();
                if (utcSeconds == 0u) utcSeconds = (uint)max(1.0, _EditorDate);

                int  tzOff     = VRC_GetTimezoneOffsetSeconds();
                int  localSecs = (int)utcSeconds + tzOff;
                uint udays     = (uint)max(0, localSecs) / 86400u;

                int year,month,day;
                CivilFromDays(udays,year,month,day);

                uint uyear=(uint)year; uint umonth=(uint)month; uint uday=(uint)day;
                int y0=(int)((uyear /1000u)%10u); int y1=(int)((uyear / 100u)%10u);
                int y2=(int)((uyear /  10u)%10u); int y3=(int)( uyear        %10u);
                int m0=(int)((umonth/ 10u)%10u);  int m1=(int)( umonth       %10u);
                int d0=(int)((uday  / 10u)%10u);  int d1=(int)( uday         %10u);

                uint ulocalSecs = (uint)max(0, localSecs);
                uint timeOfDay  = ulocalSecs % 86400u;
                uint uhour24 = timeOfDay / 3600u;
                uint uminute = (timeOfDay % 3600u) / 60u;
                uint usecond = timeOfDay % 60u;
                bool use12Hour = _DateHourMode != 0;
                bool isPM = uhour24 >= 12u;
                uint uhour = uhour24;
                if (use12Hour)
                {
                    uhour = uhour24 % 12u;
                    if (uhour == 0u) uhour = 12u;
                }
                int h0  = (int)(uhour   / 10u); int h1  = (int)(uhour   % 10u);
                int mi0 = (int)(uminute / 10u); int mi1 = (int)(uminute % 10u);
                int s0  = (int)(usecond / 10u); int s1  = (int)(usecond % 10u);
                bool showAmPm = _DateShowAmPm > 0.5 && (_DateShowFlags & 8) != 0;

                int totalCells = GetTotalCells(_DateFormat, _DateShowFlags, showAmPm);
                if (totalCells <= 0) return 0.0;
                float fc      = (float)totalCells;
                int    cell   = clamp((int)floor(localUV.x * fc), 0, totalCells - 1);
                float2 cellUV = float2(frac(localUV.x * fc), localUV.y);
                int content = GetCellContent(_DateFormat, _DateShowFlags, showAmPm, isPM, cell,
                                             y0,y1,y2,y3, m0,m1, d0,d1,
                                             h0,h1, mi0,mi1, s0,s1);

                if (content == -4) return 0.0;
                if (_DateUseFontTex > 0.5)
                {
                    float cols = max(_DateFontCols, 1.0);
                    float rows = max(_DateFontRows, 1.0);
                    if (content != -4) return SampleFontTex(cellUV, content, cols, rows).a;
                }
                if      (content >= 0)  return DrawDigit (cellUV, content);
                else if (content == -1) return DrawSlash  (cellUV);
                else if (content == -2) return DrawHyphen (cellUV);
                else if (content == -3) return DrawColon  (cellUV);
                else                    return 0.0;
            }

            float4 fragRender(v2f i) : SV_Target
            {
                if (_DateEnable < 0.5) discard;

                float alpha = GetDateOverlayAlpha(i.uv);
                if (alpha <= 0.0) discard;

                float2 localUV = saturate(i.uv * _DateTex_ST.xy + _DateTex_ST.zw);
                float2 mainUV = localUV * _MainTex_ST.xy + _MainTex_ST.zw;
                float4 mainCol = tex2D(_MainTex, mainUV) * _Color;
                return float4(mainCol.rgb, mainCol.a * alpha);
            }
            ENDHLSL
